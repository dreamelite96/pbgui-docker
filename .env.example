# .env.example — Copy this file to .env and adjust values to your needs.
# docker-compose.yml reads from .env automatically; all values below are the
# defaults used when .env is absent or a variable is left unset.

# ── Container identity ────────────────────────────────────────────────────────
# Local image name used to tag the built image (no registry push assumed).
PBGUI_IMAGE_NAME=pbgui-docker
PBGUI_IMAGE_TAG=latest
PBGUI_CONTAINER_NAME=pbgui

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host-side ports mapped to the container.  Change these if 8501 / 8000 are
# already in use on your host — the internal container ports stay fixed.
PBGUI_WEBUI_PORT=8501
PBGUI_API_PORT=8000

# ── Resource limits ───────────────────────────────────────────────────────────
# Adjust to match your host hardware.  Memory accepts Docker size strings
# (e.g. 4096M, 4g).  CPU is expressed as a fractional number of cores.
PBGUI_CPU_LIMIT=4
PBGUI_MEMORY_LIMIT=8192M